// =========================================================================
// Learn Platform · Prisma Schema
// =========================================================================
// Plataforma educativa multi-materia. La filosofía:
//
//  - Subject (Math, Reading, Science, English…) agrupa LearningPaths.
//  - LearningPath (Primary 1, Initial Reading…) tiene Units.
//  - Unit tiene Lessons.
//  - Lesson tiene Exercises.
//  - ExerciseKind representa la INTERACCIÓN (MULTIPLE_CHOICE, DRAG_DROP,
//    INPUT, DRAW, MATCH, SORT, AUDIO, SPEAK) — no la materia. Esto permite
//    reutilizar el motor entre subjects.
//  - Children se enrollan a paths independientemente (multi-materia paralela).
//
// Auth: Better Auth (user/session/account/verification).
// =========================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =========================================================================
// AUTH · Better Auth schema (formato oficial 1.x)
// =========================================================================
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Extensiones propias.
  parentalPin   String?
  plan          SubscriptionPlan @default(FREE)
  premiumUntil      DateTime?
  premiumAssignedAt DateTime?
  premiumNote       String?

  sessions Session[]
  accounts Account[]
  children Child[]
  premiumGrants         PremiumGrant[] @relation("PremiumGrantsForUser")
  premiumGrantsAssigned PremiumGrant[] @relation("PremiumGrantsAssignedBy")

  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  password              String?
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("account")
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@index([identifier])
  @@map("verification")
}

enum SubscriptionPlan {
  FREE
  PREMIUM
  FAMILY
}

model PremiumGrant {
  id          String           @id @default(cuid())
  userId      String
  adminUserId String?
  plan        SubscriptionPlan
  startsAt    DateTime         @default(now())
  endsAt      DateTime?
  note        String?
  createdAt   DateTime         @default(now())

  user      User  @relation("PremiumGrantsForUser", fields: [userId], references: [id], onDelete: Cascade)
  adminUser User? @relation("PremiumGrantsAssignedBy", fields: [adminUserId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([adminUserId])
  @@map("premium_grants")
}

// =========================================================================
// CHILDREN
// =========================================================================
model Child {
  id         String    @id @default(cuid())
  parentId   String
  name       String
  birthDate  DateTime?
  avatar     String

  // Gamificación (compartida entre subjects).
  hearts     Int       @default(5)
  gems       Int       @default(0)
  xp         Int       @default(0)
  level      Int       @default(1)
  streak     Int       @default(0)
  lastPlayAt DateTime?

  createdAt  DateTime  @default(now())

  parent       User               @relation(fields: [parentId], references: [id], onDelete: Cascade)
  enrollments  Enrollment[]
  progresses   Progress[]
  attempts     Attempt[]
  masteries    Mastery[]
  inventory    Inventory[]
  achievements ChildAchievement[]
  weeklyXP     WeeklyXP[]

  @@index([parentId])
  @@map("children")
}

// =========================================================================
// EDUCATIONAL STRUCTURE
// Subject → LearningPath → Unit → Lesson → Exercise
// =========================================================================
model Subject {
  id          String  @id @default(cuid())
  slug        String  @unique
  name        String
  description String?
  icon        String
  color       String
  order       Int
  // Si está disabled, se muestra como "Coming soon" pero no se puede entrar.
  isActive    Boolean @default(true)
  createdAt   DateTime @default(now())

  learningPaths LearningPath[]

  @@map("subjects")
}

enum EducationLevel {
  INITIAL
  PRIMARY
  SECONDARY
  PREUNIVERSITY
}

model LearningPath {
  id          String         @id @default(cuid())
  subjectId   String
  slug        String         @unique
  name        String
  description String?
  level       EducationLevel
  grade       Int?
  difficulty  Int            @default(1)
  isPremium   Boolean        @default(false)
  order       Int
  createdAt   DateTime       @default(now())

  subject     Subject      @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  units       Unit[]
  enrollments Enrollment[]

  @@index([subjectId])
  @@map("learning_paths")
}

model Unit {
  id             String  @id @default(cuid())
  learningPathId String
  slug           String
  title          String
  description    String?
  icon           String?
  color          String?
  order          Int
  createdAt      DateTime @default(now())

  learningPath LearningPath @relation(fields: [learningPathId], references: [id], onDelete: Cascade)
  lessons      Lesson[]

  @@unique([learningPathId, slug])
  @@index([learningPathId])
  @@map("units")
}

model Lesson {
  id               String   @id @default(cuid())
  unitId           String
  slug             String
  title            String
  description      String?
  order            Int
  xpReward         Int      @default(20)
  estimatedMinutes Int?
  audioUrl         String?
  createdAt        DateTime @default(now())

  unit       Unit       @relation(fields: [unitId], references: [id], onDelete: Cascade)
  exercises  Exercise[]
  progresses Progress[]

  @@unique([unitId, slug])
  @@index([unitId])
  @@map("lessons")
}

// =========================================================================
// ENROLLMENTS
// Children pueden estar enrolled en múltiples paths simultáneamente
// (Math Primary 2 + Reading Initial + English Beginner, por ejemplo).
// =========================================================================
model Enrollment {
  id              String   @id @default(cuid())
  childId         String
  learningPathId  String
  // Punteros para reanudar donde quedó (sin tener que recomputarlo cada vez).
  currentUnitId   String?
  currentLessonId String?
  startedAt       DateTime @default(now())

  child        Child        @relation(fields: [childId], references: [id], onDelete: Cascade)
  learningPath LearningPath @relation(fields: [learningPathId], references: [id], onDelete: Cascade)

  @@unique([childId, learningPathId])
  @@index([childId])
  @@index([learningPathId])
  @@map("enrollments")
}

// =========================================================================
// EXERCISE ENGINE
// Kinds = INTERACCIONES (no materias). El mismo MULTIPLE_CHOICE sirve
// para "¿cuántas estrellas?" en Math o "¿qué palabra suena igual?" en Reading.
// =========================================================================
enum ExerciseKind {
  MULTIPLE_CHOICE  // elegir 1 entre N opciones (texto o número)
  DRAG_DROP        // arrastrar items a una zona
  SORT             // ordenar items en una secuencia
  MATCH            // emparejar pares
  INPUT            // tipear una respuesta (teclado numérico o texto)
  DRAW             // trazar/dibujar (recognizer)
  AUDIO            // escuchar y responder
  SPEAK            // hablar (speech-to-text)
  TEACH            // momento de enseñanza (no calificado, precede a la práctica)
}

model Exercise {
  id           String       @id @default(cuid())
  lessonId     String
  kind         ExerciseKind
  order        Int
  title        String?
  prompt       String
  instructions String?
  payload      Json
  solution     Json
  hints        Json?
  explanation  String?
  difficulty   Int          @default(1)
  xpReward     Int          @default(5)
  audioUrl     String?
  createdAt    DateTime     @default(now())

  lesson    Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  attempts  Attempt[]
  masteries Mastery[]

  @@index([lessonId])
  @@map("exercises")
}

// =========================================================================
// PROGRESS / ATTEMPTS / MASTERY
// =========================================================================
model Progress {
  id            String    @id @default(cuid())
  childId       String
  lessonId      String
  completed     Boolean   @default(false)
  stars         Int       @default(0)
  bestScore     Int       @default(0)
  attemptsCount Int       @default(0)
  completedAt   DateTime?
  updatedAt     DateTime  @updatedAt

  child  Child  @relation(fields: [childId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([childId, lessonId])
  @@index([childId])
  @@map("progress")
}

model Attempt {
  id         String   @id @default(cuid())
  childId    String
  exerciseId String
  correct    Boolean
  response   Json
  timeMs     Int
  hintsUsed  Int      @default(0)
  createdAt  DateTime @default(now())

  child    Child    @relation(fields: [childId], references: [id], onDelete: Cascade)
  exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@index([childId, createdAt])
  @@index([exerciseId])
  @@map("attempts")
}

// Mastery simplificado: masteryLevel (0-1) + repetitions + nextReviewAt.
// El algoritmo SM-2 se aplica internamente en lib/srs.ts pero acá sólo
// guardamos lo necesario para revivar y mostrar progreso.
model Mastery {
  id           String    @id @default(cuid())
  childId      String
  exerciseId   String
  masteryLevel Float     @default(0)
  repetitions  Int       @default(0)
  nextReviewAt DateTime?
  updatedAt    DateTime  @updatedAt

  child    Child    @relation(fields: [childId], references: [id], onDelete: Cascade)
  exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@unique([childId, exerciseId])
  @@index([childId, nextReviewAt])
  @@map("mastery")
}

// =========================================================================
// SHOP · ACHIEVEMENTS · LEAGUE (gamificación compartida cross-subject)
// =========================================================================
enum ShopItemKind {
  ACCESSORY
  GEMS_PACK
  HEARTS_REFILL
}

enum Rarity {
  COMMON
  RARE
  EPIC
  LEGENDARY
}

model ShopItem {
  id        String       @id @default(cuid())
  slug      String       @unique
  kind      ShopItemKind
  name      String
  icon      String
  price     Int
  rarity    Rarity       @default(COMMON)
  isActive  Boolean      @default(true)

  inventory Inventory[]

  @@map("shop_items")
}

model Inventory {
  id         String   @id @default(cuid())
  childId    String
  itemId     String
  acquiredAt DateTime @default(now())
  equipped   Boolean  @default(false)

  child Child    @relation(fields: [childId], references: [id], onDelete: Cascade)
  item  ShopItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([childId, itemId])
  @@index([childId])
  @@map("inventory")
}

model Achievement {
  id          String  @id @default(cuid())
  slug        String  @unique
  name        String
  description String
  icon        String
  target      Int
  metric      String

  unlocks ChildAchievement[]

  @@map("achievements")
}

model ChildAchievement {
  id            String   @id @default(cuid())
  childId       String
  achievementId String
  unlockedAt    DateTime @default(now())

  child       Child       @relation(fields: [childId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([childId, achievementId])
  @@index([childId])
  @@map("child_achievements")
}

model WeeklyXP {
  id        String   @id @default(cuid())
  childId   String
  weekStart DateTime @db.Date
  xp        Int      @default(0)
  league    String   @default("BRONZE")

  child Child @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@unique([childId, weekStart])
  @@index([weekStart, league, xp])
  @@map("weekly_xp")
}
