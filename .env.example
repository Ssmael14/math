# ============================================================
# Paskalito · Variables de entorno
# ============================================================
# Copia este archivo como .env.local y completa los valores.

# --- Postgres (Neon) ---
# Connection string desde el dashboard de Neon.
# Una sola URL — Neon ya resuelve pooling/direct internamente.
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/learnmath?sslmode=require"

# --- Better Auth ---
# Genera un secret con: openssl rand -base64 32
BETTER_AUTH_SECRET="..."

# URL canónica del backend (sin barra al final).
#   dev:  http://localhost:3000
#   prod: la URL del deploy (Vercel, etc.)
BETTER_AUTH_URL="http://localhost:3000"

# Misma URL pero expuesta al browser (la usa lib/auth-client.ts).
NEXT_PUBLIC_BETTER_AUTH_URL="http://localhost:3000"

# URL publica del sitio para metadata, Open Graph y compartir enlaces.
#   dev:  http://localhost:3000
#   prod: https://paskalito.com o URL de Vercel mientras no haya dominio final.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# --- Google OAuth ---
# Google Cloud Console → APIs & Services → Credentials → OAuth client ID.
# Authorized redirect URI: ${BETTER_AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID="..."
GOOGLE_CLIENT_SECRET="..."

# --- Resend (emails transaccionales) ---
# https://resend.com/api-keys
# Usado para el mail de "olvide mi contraseña". Si lo dejas vacio en dev,
# el link se loguea en consola en vez de mandarse por mail.
RESEND_API_KEY="re_..."

# --- ElevenLabs TTS (audio del enunciado para pre-lectores) ---
# https://elevenlabs.io/app/settings/api-keys
# SOLO se usa al correr `npm run gen:audio` (nunca en runtime). Si lo dejas
# vacio, el boton de audio igual funciona con la voz del navegador (Web Speech).
ELEVENLABS_API_KEY=""
# Voz fija de Paskalito. Default = Rachel (multilingue). Ver /app/voice-library.
ELEVENLABS_VOICE_ID="21m00Tcm4TlvDq8ikWAM"
ELEVENLABS_MODEL_ID="eleven_multilingual_v2"

# --- Vercel Blob (almacenamiento de los mp3 generados) ---
# https://vercel.com/docs/storage/vercel-blob
# Token de lectura/escritura; se usa solo desde `npm run gen:audio`.
BLOB_READ_WRITE_TOKEN=""

# --- Cloudinary (imagenes dinamicas) ---
# Usar para imagenes generadas, subidas desde admin o contenido dinamico.
# Los assets estaticos de marca pueden quedarse en public/brand.
# Opcion A: una sola URL desde Cloudinary Dashboard.
CLOUDINARY_URL=""
# Opcion B: variables separadas si no usas CLOUDINARY_URL.
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
CLOUDINARY_UPLOAD_FOLDER="paskalito/uploads"

# --- Admin (panel mínimo /admin/audio) ---
# Emails con acceso al panel admin, separados por coma. Aún no hay modelo
# de roles; esto gatea el panel hasta construir el admin completo.
ADMIN_EMAILS=""
