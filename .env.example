# ============================================================
# LearnMath · Variables de entorno
# ============================================================
# Copiá este archivo como .env.local y completá los valores.

# --- Postgres (Prisma) ---
# DEV LOCAL: usá el docker-compose de abajo
DATABASE_URL="postgresql://postgres:dev@localhost:5432/learnmath?schema=public"
DIRECT_URL="postgresql://postgres:dev@localhost:5432/learnmath?schema=public"

# PROD (Supabase): Settings → Database → Connection string
# DATABASE_URL="postgresql://postgres.xxx:PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres.xxx:PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres"

# --- Supabase Auth (cliente) ---
# Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://xxxxxxxxxxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGci..."

# --- Opcional ---
# NODE_ENV="development"
